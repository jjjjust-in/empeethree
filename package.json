{
  "name": "empeethree",
  "version": "1.0.0",
  "description": "A terminal-aesthetic desktop MP3 player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "watch": "NODE_ENV=development electron .",
    "dev": "electron . --dev",
    "gif": "EMPEETHREE_CAPTURE_GIF=1 electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.empeethree.app",
    "productName": "Empeethree",
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Empeethree"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1"
  }
}
